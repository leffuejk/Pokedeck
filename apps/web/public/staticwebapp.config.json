{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*", "/favicon.ico", "/robots.txt"]
  },
  "routes": [{ "route": "/api/*", "allowedRoles": ["anonymous", "authenticated"] }],
  "responseOverrides": {
    "404": { "rewrite": "/index.html", "statusCode": 200 }
  }
}
