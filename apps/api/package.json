{
  "name": "@pokedeck/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "cards:sync": "tsx src/scripts/sync-cards.ts",
    "seed:archetypes": "tsx src/scripts/seed-archetypes.ts",
    "seed:collection": "tsx src/scripts/seed-collection.ts"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@auth/drizzle-adapter": "^1.7.4",
    "@azure/ai-projects": "^1.0.0",
    "@azure/identity": "^4.5.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.2",
    "@pokedeck/shared": "*",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.0.0"
  }
}
