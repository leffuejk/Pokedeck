# ─────────────────────────────────────────────────────────────
# Pokedeck environment. Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# --- API server ---
NODE_ENV=development
PORT=3000
# Public origin of the web app (used for CORS + Auth.js callbacks)
WEB_ORIGIN=http://localhost:5173
# Public origin of the API itself
API_ORIGIN=http://localhost:3000

# --- Database (Azure Database for PostgreSQL Flexible Server) ---
# Local dev: postgres://postgres:postgres@localhost:5432/pokedeck
# Azure:     use the connection string from the Flexible Server + require SSL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pokedeck
DATABASE_SSL=false

# --- Auth.js (self-hosted) ---
# Generate: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-32-byte-random-string
AUTH_TRUST_HOST=true
# OAuth SSO providers (create apps in each provider's console)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- Pokémon TCG card data (https://pokemontcg.io) ---
# Optional but recommended — raises rate limit from 30/day to 20k/day
POKEMONTCG_API_KEY=

# --- Azure AI Foundry (deck coach agent) ---
# Foundry project endpoint, e.g. https://<resource>.services.ai.azure.com/api/projects/<project>
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=
# Deployed model name used by the agent, e.g. gpt-4o
AZURE_AI_FOUNDRY_MODEL_DEPLOYMENT=gpt-4o
# Optional: reuse a pre-created agent id instead of creating one at boot
AZURE_AI_FOUNDRY_AGENT_ID=
